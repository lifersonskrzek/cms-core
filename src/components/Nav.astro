---
const navLinks = [
  { label: 'Blog', href: '/blog' },
  { label: 'Sobre', href: '/sobre' },
  { label: 'Recursos', href: '/recursos' },
  { label: 'Contato', href: '/contato' },
];
const whatsapp = 'https://wa.me/5551998181917';
---

<header class="w-full bg-white border-b border-gray-100 sticky top-0 z-50">
  <div class="max-w-[1100px] mx-auto px-6 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 text-primary font-semibold text-lg no-underline">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.35-4.35"/>
        <path d="M11 8v6M8 11h6"/>
      </svg>
      Líferson
    </a>

    <!-- Links desktop -->
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a href={link.href} class="text-sm text-secondary hover:text-accent transition-colors font-medium no-underline">
          {link.label}
        </a>
      ))}
    </nav>

    <!-- CTA WhatsApp -->
    <a
      href={whatsapp}
      target="_blank"
      rel="noopener noreferrer"
      class="hidden md:flex items-center gap-2 bg-accent hover:bg-secondary text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors no-underline"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
        <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.529 5.855L0 24l6.335-1.505A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.007-1.37l-.36-.214-3.724.885.936-3.617-.235-.372A9.818 9.818 0 1112 21.818z"/>
      </svg>
      Fale Comigo
    </a>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="md:hidden text-primary" aria-label="Abrir menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 px-6 py-4 flex flex-col gap-4">
    {navLinks.map(link => (
      <a href={link.href} class="text-sm text-secondary hover:text-accent font-medium no-underline">
        {link.label}
      </a>
    ))}
    <a
      href={whatsapp}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-2 bg-accent text-white text-sm font-medium px-4 py-2 rounded-lg w-fit no-underline"
    >
      Fale Comigo
    </a>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
