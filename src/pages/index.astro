---
import BaseLayout from '../layouts/BaseLayout.astro';
import { readData, getRecentPosts } from '../lib/readData';

const siteConfig = readData('siteConfig.json');
const posts = await getRecentPosts(3);
---

<BaseLayout title="Líferson — Consultor de Tráfego Orgânico" description="Seu conteúdo posicionado onde a decisão de compra acontece.">

  <!-- HERO -->
  <section class="bg-white pt-20 pb-16 px-6">
    <div class="max-w-[1100px] mx-auto flex flex-col items-start gap-6">
      <span class="text-xs font-medium text-accent uppercase tracking-widest border border-accent/30 bg-accent/5 px-3 py-1 rounded-full">
        Consultor de Tráfego Orgânico
      </span>
      <h1 class="text-4xl md:text-5xl font-bold text-primary leading-tight max-w-2xl">
        Seu conteúdo posicionado onde a decisão de compra acontece.
      </h1>
      <p class="text-lg text-secondary/80 max-w-xl leading-relaxed">
        10 anos de SEO, GEO e desenvolvimento web a serviço da visibilidade orgânica de empresas que querem crescer de forma consistente.
      </p>
      <div class="flex flex-wrap gap-4 mt-2">
        <a href="/blog" class="bg-primary hover:bg-secondary text-white font-medium px-6 py-3 rounded-lg transition-colors no-underline">
          Ver artigos
        </a>
        <a href="https://wa.me/5551998181917" target="_blank" rel="noopener noreferrer" class="border border-primary text-primary hover:bg-primary hover:text-white font-medium px-6 py-3 rounded-lg transition-colors no-underline">
          Fale Comigo
        </a>
      </div>
    </div>
  </section>

  <!-- ESPECIALIDADES -->
  <section class="bg-surface py-16 px-6">
    <div class="max-w-[1100px] mx-auto">
      <h2 class="text-2xl font-semibold text-primary mb-2">Especialidades</h2>
      <p class="text-secondary/70 mb-10">As frentes que domino para gerar resultado orgânico consistente.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-xl p-6 border border-gray-100 hover:border-accent/40 transition-colors">
          <div class="w-10 h-10 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#3D7EBF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </div>
          <h3 class="font-semibold text-primary mb-2">SEO Técnico</h3>
          <p class="text-sm text-secondary/70 leading-relaxed">Arquitetura, velocidade, indexação e estrutura que os algoritmos respeitam.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-100 hover:border-accent/40 transition-colors">
          <div class="w-10 h-10 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#3D7EBF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2z"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10A15.3 15.3 0 0 1 12 2z"/></svg>
          </div>
          <h3 class="font-semibold text-primary mb-2">GEO</h3>
          <p class="text-sm text-secondary/70 leading-relaxed">Otimização para motores de busca generativos — apareça no ChatGPT, Gemini e Perplexity.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-100 hover:border-accent/40 transition-colors">
          <div class="w-10 h-10 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#3D7EBF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M3 3h18v18H3zM3 9h18M9 21V9"/></svg>
          </div>
          <h3 class="font-semibold text-primary mb-2">Inbound Marketing</h3>
          <p class="text-sm text-secondary/70 leading-relaxed">Estratégia de conteúdo que atrai, engaja e converte ao longo de toda a jornada.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-100 hover:border-accent/40 transition-colors">
          <div class="w-10 h-10 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#3D7EBF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <h3 class="font-semibold text-primary mb-2">Desenvolvimento Web</h3>
          <p class="text-sm text-secondary/70 leading-relaxed">HTML, CSS, JS e frameworks modernos — SEO com raiz de desenvolvedor.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOG PREVIEW -->
  <section class="bg-white py-16 px-6">
    <div class="max-w-[1100px] mx-auto">
      <div class="flex items-center justify-between mb-10">
        <div>
          <h2 class="text-2xl font-semibold text-primary mb-1">Artigos recentes</h2>
          <p class="text-secondary/70">SEO, GEO e ferramentas de IA para quem quer resultado orgânico.</p>
        </div>
        <a href="/blog" class="text-sm text-accent font-medium hover:underline no-underline hidden md:block">Ver todos →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {posts.map((post) => (
          <a href={post.href} class="group bg-white border border-gray-100 rounded-xl overflow-hidden hover:border-accent/40 transition-colors no-underline">
            {post.image && (
              <img src={post.image} alt={post.title} class="w-full h-44 object-cover" />
            )}
            <div class="p-5">
              {post.category && (
                <span class="text-xs text-accent font-medium uppercase tracking-wide">{post.category}</span>
              )}
              <h3 class="text-base font-semibold text-primary mt-2 mb-2 group-hover:text-accent transition-colors leading-snug">{post.title}</h3>
              <p class="text-sm text-secondary/70 leading-relaxed line-clamp-2">{post.description}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="mt-8 md:hidden">
        <a href="/blog" class="text-sm text-accent font-medium no-underline">Ver todos os artigos →</a>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="bg-primary py-16 px-6">
    <div class="max-w-[600px] mx-auto text-center">
      <h2 class="text-2xl font-semibold text-white mb-3">Receba conteúdo direto no seu email</h2>
      <p class="text-blue-200 mb-8 leading-relaxed">Estratégias de SEO, GEO e IA toda semana — sem enrolação, só o que funciona.</p>
      <form class="flex flex-col sm:flex-row gap-3 justify-center">
        <input
          type="email"
          placeholder="seu@email.com"
          class="flex-1 px-4 py-3 rounded-lg text-primary text-sm outline-none border-0 max-w-sm"
        />
        <button type="submit" class="bg-accent hover:bg-blue-500 text-white font-medium px-6 py-3 rounded-lg transition-colors whitespace-nowrap">
          Quero receber
        </button>
      </form>
      <p class="text-xs text-blue-300 mt-4">Sem spam. Cancele quando quiser.</p>
    </div>
  </section>

  <!-- REDES SOCIAIS PLACEHOLDER -->
  <section class="bg-surface py-16 px-6">
    <div class="max-w-[1100px] mx-auto text-center">
      <h2 class="text-2xl font-semibold text-primary mb-3">Conteúdo em vídeo em breve</h2>
      <p class="text-secondary/70 mb-8">Estou preparando conteúdo para YouTube e LinkedIn. Me siga para ser o primeiro a saber.</p>
      <div class="flex justify-center gap-4">
        <span class="flex items-center gap-2 border border-gray-200 text-secondary/60 text-sm font-medium px-5 py-3 rounded-lg cursor-default">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          YouTube — em breve
        </span>
        <span class="flex items-center gap-2 border border-gray-200 text-secondary/60 text-sm font-medium px-5 py-3 rounded-lg cursor-default">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn — em breve
        </span>
      </div>
    </div>
  </section>

</BaseLayout>
