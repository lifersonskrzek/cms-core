---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<BaseLayout title="Contato — Líferson" description="Entre em contato com Líferson para falar sobre SEO, GEO e tráfego orgânico.">

  <PageHeader badge="Fale Comigo" breadcrumb={[{ label: 'Início', href: '/' }, { label: 'Contato' }]} />

  <section class="bg-white pt-8 pb-20 px-6">
    <div class="max-w-[1100px] mx-auto">

      <div class="max-w-xl">
        <h1 class="text-4xl font-bold leading-tight text-primary mt-4 mb-4">
          Vamos conversar?
        </h1>
        <p class="text-lg text-secondary/70 leading-relaxed mb-10">
          Se você quer aumentar o tráfego orgânico do seu negócio, tem dúvidas sobre SEO ou GEO, ou quer saber como posso ajudar — me chama.
        </p>

        <div class="flex flex-col gap-4">
          <a
            href="https://wa.me/5551998181917"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 p-5 border border-gray-100 rounded-xl hover:border-accent/40 transition-colors no-underline group"
          >
            <div class="w-10 h-10 bg-green-50 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="#22c55e" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.529 5.855L0 24l6.335-1.505A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.007-1.37l-.36-.214-3.724.885.936-3.617-.235-.372A9.818 9.818 0 1112 21.818z"/>
              </svg>
            </div>
            <div>
              <p class="font-medium text-primary group-hover:text-accent transition-colors">WhatsApp</p>
              <p class="text-sm text-secondary/60">Resposta rápida — me chama lá</p>
            </div>
          </a>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>