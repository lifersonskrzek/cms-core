---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<BaseLayout title="Recursos — Líferson" description="Artigos essenciais, ferramentas recomendadas, materiais gratuitos e leituras externas sobre SEO, GEO e IA.">

  <PageHeader badge="Arsenal Orgânico" breadcrumb={[{ label: 'Início', href: '/' }, { label: 'Recursos' }]} />

  <section class="bg-white pt-8 pb-20 px-6">
    <div class="max-w-[1100px] mx-auto">

      <div class="max-w-2xl mb-16">
        <h1 class="text-4xl font-bold leading-tight text-primary mt-4 mb-4">
          Tudo que uso e recomendo
        </h1>
        <p class="text-lg text-secondary/70 leading-relaxed">
          Uma biblioteca curada de artigos, ferramentas e referências para quem quer resultado orgânico de verdade.
        </p>
      </div>

      <!-- Bloco 1: Artigos Essenciais -->
      <div class="mb-16">
        <h2 class="text-xl font-semibold text-primary mb-2">Artigos essenciais</h2>
        <p class="text-secondary/70 text-sm mb-6">Os melhores artigos do blog — curados para quem está começando ou quer aprofundar.</p>
        <div class="bg-surface rounded-xl p-8 text-center border border-gray-100">
          <p class="text-secondary/50 text-sm">Em breve — os primeiros artigos serão adicionados aqui.</p>
        </div>
      </div>

      <!-- Bloco 2: Ferramentas -->
      <div class="mb-16">
        <h2 class="text-xl font-semibold text-primary mb-2">Ferramentas que uso</h2>
        <p class="text-secondary/70 text-sm mb-6">Lista curta e honesta das ferramentas que fazem parte do meu dia a dia.</p>
        <div class="bg-surface rounded-xl p-8 text-center border border-gray-100">
          <p class="text-secondary/50 text-sm">Em breve — ferramentas recomendadas com links e descrições.</p>
        </div>
      </div>

      <!-- Bloco 3: Materiais Gratuitos -->
      <div class="mb-16">
        <h2 class="text-xl font-semibold text-primary mb-2">Materiais gratuitos</h2>
        <p class="text-secondary/70 text-sm mb-6">Checklists, guias e templates para baixar e usar agora.</p>
        <div class="bg-surface rounded-xl p-8 text-center border border-gray-100">
          <p class="text-secondary/50 text-sm">Em breve — materiais gratuitos para download.</p>
        </div>
      </div>

      <!-- Bloco 4: Leituras Externas -->
      <div class="mb-16">
        <h2 class="text-xl font-semibold text-primary mb-2">Leituras externas</h2>
        <p class="text-secondary/70 text-sm mb-6">Fontes e referências que eu realmente uso e consulto.</p>
        <div class="bg-surface rounded-xl p-8 text-center border border-gray-100">
          <p class="text-secondary/50 text-sm">Em breve — referências externas selecionadas.</p>
        </div>
      </div>

      <!-- Bloco 5: Newsletter -->
      <div class="bg-primary rounded-xl p-10 text-center">
        <h2 class="text-2xl font-semibold text-white mb-3">Receba conteúdo direto no seu email</h2>
        <p class="text-blue-200 mb-8 leading-relaxed">Estratégias de SEO, GEO e IA toda semana — sem enrolação.</p>
        <form class="flex flex-col sm:flex-row gap-3 justify-center">
          <input type="email" placeholder="seu@email.com" class="flex-1 px-4 py-3 rounded-lg text-primary text-sm outline-none border-0 max-w-sm" />
          <button type="submit" class="bg-accent hover:bg-blue-500 text-white font-medium px-6 py-3 rounded-lg transition-colors whitespace-nowrap">
            Quero receber
          </button>
        </form>
        <p class="text-xs text-blue-300 mt-4">Sem spam. Cancele quando quiser.</p>
      </div>

    </div>
  </section>

</BaseLayout>