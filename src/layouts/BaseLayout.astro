---
import '../styles/global.css';
import { readData } from '../lib/readData';
import HeadPlugins from '../plugins/_slots/HeadPlugins.astro';
import BodyEndPlugins from '../plugins/_slots/BodyEndPlugins.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const siteConfig = readData('siteConfig.json');
const pluginsConfig = readData('pluginsConfig.json', {});
const gscVerificationTag = (pluginsConfig as any)?.searchConsole?.verificationTag?.trim() || '';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  bodyClass?: string;
}

const {
  title = siteConfig.name,
  description = siteConfig.description,
  image = '',
  type = 'website',
  bodyClass = '',
} = Astro.props;

const formattedTitle = title === siteConfig.name ? title : `${title} | ${siteConfig.name}`;
const siteUrl = siteConfig.url || Astro.url.origin;
const socialImage = image?.startsWith('http') ? image : image ? new URL(image, siteUrl).toString() : '';
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
  <title>{formattedTitle}</title>
  <meta name="description" content={description}>
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
  <link rel="icon" href={siteConfig.favicon || '/favicon.svg'} />

  <!-- Google Search Console verification -->
  {gscVerificationTag && (
    gscVerificationTag.startsWith('<')
      ? <Fragment set:html={gscVerificationTag} />
      : <meta name="google-site-verification" content={gscVerificationTag} />
  )}

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:title" content={formattedTitle} />
  <meta property="og:description" content={description} />
  {socialImage && <meta property="og:image" content={socialImage} />}
  <meta property="og:url" content={Astro.url} />

  <!-- Google Fonts — DM Sans -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- Head plugins: GA, Meta Pixel, AdSense -->
  <HeadPlugins />
</head>

<body class:list={['min-h-screen flex flex-col', bodyClass]}>
  <Nav />

  <main class="flex-1">
    <slot />
  </main>

  <Footer />

  <!-- Body-end plugins: EmailPopup, CookieConsent -->
  <BodyEndPlugins />
</body>
</html>
